  "glossary": [
    {
      "section": "Roots",
      "term": "PROJECTS_ROOT",
      "definition": "Base path for the project layer.\nDefault: `/Users/involute/projects`."
    },
    {
      "section": "Roots",
      "term": "DATA_ROOT",
      "definition": "Base path for the data layer (outside git).\nDefault: `/Users/involute/data`.\nConnected to projects via symlinks when needed."
    },
    {
      "section": "Roots",
      "term": "KNOWLEDGE_ROOT",
      "definition": "Base path for the knowledge layer (Obsidian vault).\nDefault: `/Users/involute/knowledge`.\nNot scanned by system map — Knowledge layer is Obsidian-only.\n---"
    },
    {
      "section": "Core Concepts",
      "term": "Domain",
      "definition": "A logical grouping within a layer. Top-level folders under PROJECTS_ROOT or DATA_ROOT.\n| Domain    | Purpose                                      |\n|-----------|----------------------------------------------|\n| cursor    | Cursor IDE context: agents, registry, rules  |\n| lab       | Research, experiments, prototypes            |\n| public    | Personal brand, static sites                 |\n| work      | Employer-specific projects                   |\n| business  | Commercial side projects                     |"
    },
    {
      "section": "Core Concepts",
      "term": "Project",
      "definition": "A directory under a domain in the **project layer**. E.g. `lab/ab-stat-os`, `work/kontur`.\nMay have git (GitHub/GitLab) or be a plain folder. Badge shows: GitHub / GitLab / folder."
    },
    {
      "section": "Core Concepts",
      "term": "Knowledge base",
      "definition": "The Obsidian vault at `knowledge/involutevault` (KNOWLEDGE_ROOT). Separate layer, not under projects.\nMarkdown notes, links, graph. Not shown on system map."
    },
    {
      "section": "Core Concepts",
      "term": "Data area",
      "definition": "A path under **DATA_ROOT** for raw, derived, logs, cache, or secrets.\nGrouped by domain (e.g. `data/lab/`, `data/work/`)."
    },
    {
      "section": "Core Concepts",
      "term": "Artifact",
      "definition": "A generated output: reports, dashboards, HTML, JSON.\nLives under `reports/` or `public/` in projects. Never edited manually.\n---"
    },
    {
      "section": "Agent Types",
      "term": "Prompt Agent (Cursor)",
      "definition": "LLM persona definition in `cursor/agents/*.md`.\nPurpose: specialized AI instructions (lab_curator, ops_monitor).\n**Not executable** — prompts, not scripts."
    },
    {
      "section": "Agent Types",
      "term": "Job / Task / Pipeline",
      "definition": "Executable script or DAG (e.g. via launchd).\nPurpose: fetch data, normalize, generate reports on a schedule.\n**Executable** — runs automatically or via CLI.\n---"
    },
    {
      "section": "Runtime State",
      "term": "Logs",
      "definition": "Execution records from jobs/pipelines.\nRetention: see project-specific docs if any."
    },
    {
      "section": "Runtime State",
      "term": "Cache / Index",
      "definition": "Derived structures for fast lookup (FTS index, context JSON).\nRegenerable from source."
    },
    {
      "section": "Runtime State",
      "term": "Secrets",
      "definition": "Sensitive files (API keys, sessions). Stored in `data/_secrets`.\nExcluded from sync and exports.\n---"
    }
  ]
}
